---
import projects from '../data/projects.json';

const categoryLabels: Record<string, string> = {
  platform: 'Platform',
  devtool: 'Dev Tool',
  webapp: 'Web App',
  game: 'Game',
  iot: 'IoT',
};
---

<section
  id="projects"
  style="
    padding: 5rem 1.5rem;
    background: rgba(26, 31, 46, 0.3);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  "
>
  <div style="max-width: 1200px; margin: 0 auto;">
    <div style="margin-bottom: 2.5rem;">
      <span class="section-label">What I've Built</span>
      <h2 style="
        font-size: clamp(1.75rem, 3.5vw, 2.25rem);
        font-weight: 700;
        margin: 0.5rem 0 0.75rem;
        color: var(--color-text);
        letter-spacing: -0.01em;
      ">
        Projects
      </h2>
      <p style="color: var(--color-muted); font-size: 1rem; margin: 0; max-width: 600px;">
        From sold SaaS to C++ game engines. Filter by category or click any tag.
      </p>
    </div>

    <!-- Filter Bar -->
    <div id="filter-bar" style="
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 2rem;
      align-items: center;
    ">
      <button class="filter-btn active" data-filter-type="category" data-filter-value="all">All</button>
      <button class="filter-btn" data-filter-type="category" data-filter-value="platform">Platforms</button>
      <button class="filter-btn" data-filter-type="category" data-filter-value="devtool">Dev Tools</button>
      <button class="filter-btn" data-filter-type="category" data-filter-value="webapp">Web Apps</button>
      <button class="filter-btn" data-filter-type="category" data-filter-value="game">Games</button>
      <button class="filter-btn" data-filter-type="category" data-filter-value="iot">IoT</button>

      <!-- Active tag filter indicator -->
      <div id="tag-filter-indicator" style="display: none; align-items: center; gap: 0.5rem; margin-left: 0.5rem;">
        <span style="color: var(--color-muted); font-size: 0.8rem; font-family: var(--font-mono);">tag:</span>
        <span id="active-tag-label" class="tag-chip active" style="cursor: default;"></span>
        <button id="clear-tag-filter" style="
          background: none;
          border: none;
          color: var(--color-muted);
          cursor: pointer;
          font-size: 1rem;
          padding: 0 0.2rem;
          line-height: 1;
          transition: color 0.15s;
        " title="Clear tag filter">×</button>
      </div>
    </div>

    <!-- Results count -->
    <p id="results-count" style="
      color: var(--color-muted);
      font-family: var(--font-mono);
      font-size: 0.75rem;
      margin: 0 0 1.5rem;
    "></p>

    <!-- Project Grid -->
    <div id="projects-grid" style="
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      column-gap: 1.25rem;
      row-gap: 2rem;
    " class="projects-grid">
      {projects.map((project) => (
        <div
          class={`project-card${project.featured ? ' card-featured' : ''}`}
          data-category={project.category}
          data-tags={JSON.stringify(project.tags)}
          data-id={project.id}
        >
          <!-- Header row: category badge -->
          <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 0.5rem;">
            <span
              class={`badge-${project.category}`}
              style="
                font-family: var(--font-mono);
                font-size: 0.65rem;
                padding: 0.2rem 0.5rem;
                border-radius: 4px;
                font-weight: 500;
                letter-spacing: 0.05em;
                text-transform: uppercase;
                flex-shrink: 0;
              "
            >
              {categoryLabels[project.category]}
            </span>
            {project.featured && (
              <span style="
                font-family: var(--font-mono);
                font-size: 0.6rem;
                color: var(--color-accent);
                border: 1px solid var(--color-accent-border);
                border-radius: 4px;
                padding: 0.15rem 0.4rem;
                letter-spacing: 0.05em;
                flex-shrink: 0;
              ">
                FEATURED
              </span>
            )}
          </div>

          <!-- Title -->
          <h3 style="
            font-size: 1rem;
            font-weight: 600;
            color: var(--color-text);
            margin: 0;
            line-height: 1.3;
          ">
            {project.title}
          </h3>

          <!-- Description -->
          <p style="
            font-size: 0.85rem;
            color: var(--color-muted);
            margin: 0;
            line-height: 1.55;
            flex: 1;
          ">
            {project.description}
          </p>

          <!-- Tags -->
          <div style="display: flex; flex-wrap: wrap; gap: 0.35rem;">
            {project.tags.map((tag) => (
              <button
                class="tag-chip"
                data-tag={tag}
                style="border: none; padding: 0.2rem 0.45rem;"
              >
                {tag}
              </button>
            ))}
          </div>

          <!-- Bottom row: links + highlight -->
          <div style="
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.5rem;
            flex-wrap: wrap;
            margin-top: auto;
            padding-top: 0.25rem;
            border-top: 1px solid var(--color-border);
          ">
            <!-- Links -->
            <div style="display: flex; align-items: center; gap: 0.75rem;">
              {project.github ? (
                <a
                  href={project.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  title="View on GitHub"
                  style="
                    color: var(--color-muted);
                    transition: color 0.15s;
                    display: flex;
                    align-items: center;
                    gap: 0.3rem;
                    font-size: 0.78rem;
                    text-decoration: none;
                  "
                  class="icon-link"
                >
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                  </svg>
                  GitHub
                </a>
              ) : project.githubLabel ? (
                <span style="
                  display: flex;
                  align-items: center;
                  gap: 0.3rem;
                  color: var(--color-muted);
                  font-size: 0.78rem;
                  font-family: var(--font-mono);
                ">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                  </svg>
                  {project.githubLabel}
                </span>
              ) : null}

              {project.live && (
                <a
                  href={project.live}
                  target="_blank"
                  rel="noopener noreferrer"
                  title="View live"
                  style="
                    color: var(--color-muted);
                    transition: color 0.15s;
                    display: flex;
                    align-items: center;
                    gap: 0.3rem;
                    font-size: 0.78rem;
                    text-decoration: none;
                  "
                  class="icon-link"
                >
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="2" y1="12" x2="22" y2="12"></line>
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                  </svg>
                  Live
                </a>
              )}
            </div>

            <!-- Highlight badge -->
            {project.highlight && (
              <span style="
                font-size: 0.72rem;
                color: var(--color-accent);
                font-family: var(--font-mono);
                background: var(--color-accent-dim);
                border: 1px solid var(--color-accent-border);
                border-radius: 4px;
                padding: 0.15rem 0.4rem;
                max-width: 200px;
                text-align: right;
                line-height: 1.4;
              ">
                {project.highlight}
              </span>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- No results -->
    <div id="no-results" style="
      display: none;
      text-align: center;
      padding: 4rem 0;
      color: var(--color-muted);
    ">
      <p style="font-size: 1.1rem; margin: 0 0 0.5rem;">No projects match this filter.</p>
      <button id="reset-filters" style="
        background: none;
        border: none;
        color: var(--color-accent);
        cursor: pointer;
        font-size: 0.9rem;
        text-decoration: underline;
        padding: 0;
      ">Clear filters</button>
    </div>
  </div>
</section>

<style>
  .icon-link:hover {
    color: var(--color-accent) !important;
  }

  @media (max-width: 1024px) {
    .projects-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }

  @media (max-width: 600px) {
    .projects-grid {
      grid-template-columns: 1fr !important;
    }
  }
</style>

<script>
  (function () {
    let activeCategory = 'all';
    let activeTag: string | null = null;

    const grid = document.getElementById('projects-grid');
    const noResults = document.getElementById('no-results');
    const resultsCount = document.getElementById('results-count');
    const tagIndicator = document.getElementById('tag-filter-indicator');
    const activeTagLabel = document.getElementById('active-tag-label');
    const clearTagBtn = document.getElementById('clear-tag-filter');
    const resetFiltersBtn = document.getElementById('reset-filters');

    function getCards() {
      return Array.from(document.querySelectorAll<HTMLElement>('.project-card'));
    }

    function applyFilters() {
      const cards = getCards();
      let visible = 0;

      cards.forEach((card) => {
        const category = card.dataset.category || '';
        const tagsRaw = card.dataset.tags || '[]';
        let tags: string[] = [];
        try { tags = JSON.parse(tagsRaw); } catch (_) {}

        const categoryMatch = activeCategory === 'all' || category === activeCategory;
        const tagMatch = !activeTag || tags.includes(activeTag);

        if (categoryMatch && tagMatch) {
          card.style.display = '';
          visible++;
        } else {
          card.style.display = 'none';
        }
      });

      if (noResults && grid) {
        if (visible === 0) {
          noResults.style.display = 'block';
          grid.style.display = 'none';
        } else {
          noResults.style.display = 'none';
          grid.style.display = '';
        }
      }

      if (resultsCount) {
        const total = cards.length;
        resultsCount.textContent = visible === total
          ? `Showing all ${total} projects`
          : `Showing ${visible} of ${total} projects`;
      }

      // Tag indicator
      if (tagIndicator && activeTagLabel) {
        if (activeTag) {
          tagIndicator.style.display = 'flex';
          activeTagLabel.textContent = activeTag;
        } else {
          tagIndicator.style.display = 'none';
        }
      }

      // Update filter buttons
      document.querySelectorAll<HTMLElement>('[data-filter-type="category"]').forEach((btn) => {
        const val = btn.dataset.filterValue || '';
        if (val === activeCategory) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });
    }

    // Category filter buttons
    document.querySelectorAll<HTMLButtonElement>('[data-filter-type="category"]').forEach((btn) => {
      btn.addEventListener('click', () => {
        activeCategory = btn.dataset.filterValue || 'all';
        applyFilters();
      });
    });

    // Tag chip clicks
    document.querySelectorAll<HTMLButtonElement>('.tag-chip[data-tag]').forEach((chip) => {
      chip.addEventListener('click', (e) => {
        e.stopPropagation();
        const tag = chip.dataset.tag || '';
        if (activeTag === tag) {
          activeTag = null;
        } else {
          activeTag = tag;
          activeCategory = 'all';
        }
        applyFilters();
      });
    });

    // Clear tag filter
    clearTagBtn?.addEventListener('click', () => {
      activeTag = null;
      applyFilters();
    });

    // Reset all filters
    resetFiltersBtn?.addEventListener('click', () => {
      activeCategory = 'all';
      activeTag = null;
      applyFilters();
    });

    // Initial render
    applyFilters();
  })();
</script>
