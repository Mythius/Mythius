---
// Contact section
---

<section
  id="contact"
  style="
    padding: 5rem 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  "
>
  <span class="section-label">Get In Touch</span>
  <h2 style="
    font-size: clamp(1.75rem, 3.5vw, 2.25rem);
    font-weight: 700;
    margin: 0.5rem 0 0.75rem;
    color: var(--color-text);
    letter-spacing: -0.01em;
  ">
    Contact
  </h2>
  <p style="
    color: var(--color-muted);
    font-size: 1rem;
    margin: 0 auto 3rem;
    max-width: 480px;
    line-height: 1.6;
  ">
    Open to new opportunities, collaborations, and interesting problems.
    No form — just reach out directly.
  </p>

  <div style="
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 3rem;
  ">
    <!-- Email -->
    <a
      href="mailto:southwickmatthias@gmail.com"
      style="
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: var(--color-card);
        border: 1px solid var(--color-border);
        border-radius: 10px;
        padding: 1.1rem 1.5rem;
        text-decoration: none;
        color: var(--color-text);
        transition: border-color 0.2s, transform 0.2s;
        min-width: 240px;
        justify-content: center;
      "
      class="contact-card"
    >
      <span style="
        width: 36px;
        height: 36px;
        border-radius: 8px;
        background: var(--color-accent-dim);
        border: 1px solid var(--color-accent-border);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      ">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
          <polyline points="22,6 12,13 2,6"></polyline>
        </svg>
      </span>
      <div style="text-align: left;">
        <div style="font-size: 0.72rem; color: var(--color-muted); font-family: var(--font-mono); letter-spacing: 0.05em; margin-bottom: 0.15rem;">EMAIL</div>
        <div style="font-size: 0.9rem; font-weight: 500;">southwickmatthias@gmail.com</div>
      </div>
    </a>

    <!-- GitHub -->
    <a
      href="https://github.com/Mythius"
      target="_blank"
      rel="noopener noreferrer"
      style="
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: var(--color-card);
        border: 1px solid var(--color-border);
        border-radius: 10px;
        padding: 1.1rem 1.5rem;
        text-decoration: none;
        color: var(--color-text);
        transition: border-color 0.2s, transform 0.2s;
        min-width: 240px;
        justify-content: center;
      "
      class="contact-card"
    >
      <span style="
        width: 36px;
        height: 36px;
        border-radius: 8px;
        background: var(--color-accent-dim);
        border: 1px solid var(--color-accent-border);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      ">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="var(--color-accent)">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
      </span>
      <div style="text-align: left;">
        <div style="font-size: 0.72rem; color: var(--color-muted); font-family: var(--font-mono); letter-spacing: 0.05em; margin-bottom: 0.15rem;">GITHUB</div>
        <div style="font-size: 0.9rem; font-weight: 500;">github.com/Mythius</div>
      </div>
    </a>

    <!-- Resume -->
    <a
      href="https://msouthwick.com/Matthias-Southwick-Resume.pdf"
      target="_blank"
      rel="noopener noreferrer"
      download
      style="
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: var(--color-card);
        border: 1px solid var(--color-border);
        border-radius: 10px;
        padding: 1.1rem 1.5rem;
        text-decoration: none;
        color: var(--color-text);
        transition: border-color 0.2s, transform 0.2s;
        min-width: 240px;
        justify-content: center;
      "
      class="contact-card"
    >
      <span style="
        width: 36px;
        height: 36px;
        border-radius: 8px;
        background: var(--color-accent-dim);
        border: 1px solid var(--color-accent-border);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      ">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <polyline points="14 2 14 8 20 8"></polyline>
          <line x1="12" y1="18" x2="12" y2="12"></line>
          <line x1="9" y1="15" x2="15" y2="15"></line>
        </svg>
      </span>
      <div style="text-align: left;">
        <div style="font-size: 0.72rem; color: var(--color-muted); font-family: var(--font-mono); letter-spacing: 0.05em; margin-bottom: 0.15rem;">RESUME</div>
        <div style="font-size: 0.9rem; font-weight: 500;">Download PDF</div>
      </div>
    </a>
  </div>
</section>

<style>
  .contact-card:hover {
    border-color: rgba(0, 212, 170, 0.4) !important;
    transform: translateY(-2px);
  }
</style>
